rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Global Safety Net default-deny catch-all
    match /{document=**} {
      allow read, write: if false;
    }

    // Primitive Definitions
    function isSignedIn() {
      return request.auth != null;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    // Schema Validation for Workspace Type
    function isValidWorkspace(data) {
      return data.keys().hasAll(['userId', 'username', 'items', 'updatedAt'])
        && data.keys().size() <= 5
        && data.userId is string && data.userId.size() <= 128
        && data.username is string && data.username.size() <= 128
        && data.items is list
        && data.updatedAt is timestamp;
    }

    // Secured scoping of workspaces
    match /workspaces/{userId} {
      allow get: if isSignedIn() && request.auth.uid == userId && isValidId(userId);
      allow list: if false; // List queries are blocked by design; we only get individual documents directly

      allow create: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidWorkspace(request.resource.data)
        && request.resource.data.userId == request.auth.uid;

      allow update: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId)
        && isValidWorkspace(request.resource.data)
        && request.resource.data.userId == request.auth.uid;

      allow delete: if isSignedIn()
        && request.auth.uid == userId
        && isValidId(userId);
    }
  }
}
